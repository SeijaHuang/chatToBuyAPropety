# LLM
# --- OpenRouter (default) ---
OPENROUTER_API_KEY=
MODEL_STRONG=anthropic/claude-sonnet-4-5
MODEL_FAST=anthropic/claude-haiku-4-5
LLM_BASE_URL=https://openrouter.ai/api/v1

